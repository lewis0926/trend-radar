  new { ticker = "XLV";  name = "Health Care Select Sector SPDR";             sector = "Healthcare" }
  new { ticker = "XLF";  name = "Financial Select Sector SPDR";               sector = "Financials" }
  new { ticker = "XLE";  name = "Energy Select Sector SPDR";                  sector = "Energy" }
  new { ticker = "XLY";  name = "Consumer Discretionary Select Sector SPDR";  sector = "Consumer Discretionary" }
  new { ticker = "XLP";  name = "Consumer Staples Select Sector SPDR";        sector = "Consumer Staples" }
  new { ticker = "XLI";  name = "Industrial Select Sector SPDR";              sector = "Industrials" }
  new { ticker = "XLB";  name = "Materials Select Sector SPDR";               sector = "Materials" }
  new { ticker = "XLRE"; name = "Real Estate Select Sector SPDR";             sector = "Real Estate" }
  new { ticker = "XLU";  name = "Utilities Select Sector SPDR";               sector = "Utilities" }
  new { ticker = "XLC";  name = "Communication Services Select Sector SPDR";  sector = "Communication Services" }
